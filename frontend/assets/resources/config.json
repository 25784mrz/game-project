{
  "game": {
    "title": "Game Project",
    "version": "1.0.0",
    "debugMode": true,
    "frameRate": 60,
    "groupList": ["default", "player", "enemy", "ground", "ui"]
  },
  "network": {
    "serverUrl": "ws://localhost:8080",
    "autoReconnect": true,
    "reconnectDelay": 3000,
    "maxReconnectAttempts": 5
  },
  "audio": {
    "bgmVolume": 0.5,
    "sfxVolume": 0.8,
    "bgmPath": "audio/bgm",
    "clickPath": "audio/click"
  },
  "resources": {
    "preload": [
      { "path": "textures/player", "type": "image" },
      { "path": "audio/bgm", "type": "audio" },
      { "path": "audio/click", "type": "audio" }
    ]
  },
  "player": {
    "speed": 5,
    "jumpForce": 10,
    "maxHealth": 100
  }
}
